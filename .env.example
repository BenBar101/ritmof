# ─── RITMOL environment variables ────────────────────────────────────────────
# Copy this file to .env and fill in your values before running `npm run dev`
# or `npm run build`.
# NEVER commit .env to version control — add it to .gitignore.

# ── Dropbox sync (optional) ──────────────────────────────────────────────────
# Required to enable Dropbox sync in Profile → Settings.
# 1. Create an app at https://www.dropbox.com/developers/apps
# 2. Choose "Scoped access" → "App folder" (or "Full Dropbox").
# 3. Enable files.content.read + files.content.write permissions.
# 4. Under OAuth 2 → Redirect URIs add your exact deployment origin followed by
#    /dropbox-callback — e.g. https://yourusername.github.io/ritmol/dropbox-callback
#    or http://localhost:5173/dropbox-callback for local dev.
#
# SECURITY: This key is inlined into the production JS bundle by Vite's
# import.meta.env substitution and is visible to anyone who inspects the compiled
# JS or a HAR export. This is expected behaviour for public-client OAuth apps.
# PKCE (used here) mitigates the risk — the App Key alone cannot complete the
# OAuth exchange without the code_verifier stored in sessionStorage.
# Rotate the key immediately if it appears in a public repository or HAR file.
VITE_DROPBOX_APP_KEY=your_dropbox_app_key_here

# ── GitHub Pages / custom base path (optional) ───────────────────────────────
# Set to your repository name if deploying to GitHub Pages under a sub-path.
# Example for https://yourusername.github.io/ritmol:
#   VITE_BASE_PATH=/ritmol
# Leave empty or omit entirely for root deployments (e.g. a custom domain).
VITE_BASE_PATH=

# ── Google Calendar integration (optional) ───────────────────────────────────
# OAuth client ID for read-only Google Calendar sync in Profile → Calendar.
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials.
# 2. Create an OAuth 2.0 Client ID of type "Web application".
# 3. Add your deployment origin as an Authorised JavaScript origin.
# 4. Enable the Google Calendar API in the same project.
#
# Alternatively, set googleClientId per-user inside ritmol-data.json —
# the build-time env var is a fallback for self-hosters who do not want to
# edit their data file.
VITE_GOOGLE_CLIENT_ID=
