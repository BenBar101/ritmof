# Copy to .env and fill in. Used at build time for GitHub Pages + single-account gate.
# For local dev without the gate, leave VITE_ALLOWED_EMAIL and VITE_GOOGLE_CLIENT_ID empty.

# Base path for GitHub Pages (e.g. repo "jarvis" -> https://user.github.io/jarvis/)
# Use a leading and trailing slash: /your-repo-name/
VITE_BASE_PATH=/

# Single-account access: only this Google email can use the app (case-insensitive).
# Leave empty to disable the gate.
VITE_ALLOWED_EMAIL=

# Google OAuth Client ID for the sign-in gate (same as Calendar or a separate Web app).
# Required when VITE_ALLOWED_EMAIL is set. Add your GitHub Pages URL to Authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID=
